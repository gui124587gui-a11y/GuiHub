{
  "name": "guihub",
  "productName": "GuiHub",
  "version": "1.0.4",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/gui124587gui-a11y/GuiHub.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc -b --noEmit",
    "electron:dev": "concurrently \"cross-env NODE_ENV=development vite --port 5173 --strictPort\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && dotenv -e .env -- electron-builder --publish always"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.13.65",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^2.2.3",
    "react-router-dom": "^7.3.0",
    "recharts": "^3.9.2",
    "spotify-web-api-node": "^5.0.2",
    "systeminformation": "^5.32.0",
    "tailwind-merge": "^3.0.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.6",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.guihub.app",
    "productName": "GuiHub",
    "directories": {
      "output": "C:/guihub-release"
    },
    "icon": "build/icon.ico",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "gui124587gui-a11y",
        "repo": "GuiHub"
      }
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "releaseInfo": {
      "releaseNotesFile": "release-notes.md"
    }
  }
}
